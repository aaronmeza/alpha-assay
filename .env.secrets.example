#
# Template for `.env.secrets`. Copy to `.env.secrets` (which is gitignored)
# and fill in real values on the host. docker-compose.yml loads this file via
# `env_file:` on the paper-trader, breadth-recorder, and grafana services.
# Values left blank here must be set before `docker compose up -d` runs in
# any environment that touches live accounts.

# --- Databento (market data) ---
DATABENTO_API_KEY=

# --- IBKR paper account ---
IBKR_ACCOUNT_ID=
IBKR_USERNAME=
IBKR_PASSWORD=

# --- IBKR connection (paper-dryrun + breadth-recorder) ---
# Defaults match the headless IB Gateway paper layout. Override only
# when running IB Gateway / TWS on a non-default host or port.
#
# Four-port matrix:
#   4002 -> IB Gateway paper   (the deployment host default; headless)
#   4001 -> IB Gateway live
#   7497 -> TWS paper          (developer laptop default)
#   7496 -> TWS live
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
# Unique per-connection. paper-dryrun defaults to 1; breadth-recorder
# defaults to 21. Do NOT collide across services on the same gateway.
IBKR_CLIENT_ID=1
# IBKR account code (e.g. DU1234567 for paper). Empty defers to the
# default account associated with the gateway login.
IBKR_ACCOUNT=

# --- ES front-month contract ---
# Full date YYYYMMDD form, NOT YYYYMM. IBKR's `lastTradeDateOrContractMonth`
# field for ESM6 (E-mini S&P June 2026) is `20260618` per ContFuture
# qualify on 2026-04-28. The YYYYMM short form (e.g. "202506") returns
# Error 200 "No security definition has been found" on this account.
# Update on the third Friday of every quarter-end month (Mar/Jun/Sep/Dec).
# Next roll target: 20260918 for ESU6 (September 2026).
ES_EXPIRY=20260618

# --- Grafana admin override (optional) ---
# If unset, docker-compose falls back to the default `alphaassay`. Override
# in production.
GF_SECURITY_ADMIN_PASSWORD=
